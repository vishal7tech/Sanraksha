<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/textSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/safety_subtitle"
        android:textSize="16sp"
        android:textColor="#7F8C8D"
        app:layout_constraintTop_toBottomOf="@id/textTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Safety Mode Toggle -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchSafetyMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/safety_mode"
        android:textSize="16sp"
        android:textColor="#2980B9"
        app:layout_constraintTop_toBottomOf="@id/textSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <!-- SOS Toggle -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchSos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enable_sos"
        android:textSize="18sp"
        android:textColor="#E74C3C"
        app:layout_constraintTop_toBottomOf="@id/switchSafetyMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />
    <!-- Mute Siren Toggle -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchMuteSiren"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mute_siren"
        android:textSize="16sp"
        android:textColor="#7F8C8D"
        app:layout_constraintTop_toBottomOf="@id/switchSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Keyword Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutKeyword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/switchMuteSiren">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/voice_prompt"
            android:maxLines="2"
            android:textSize="16sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Manual SOS Button -->
    <Button
        android:id="@+id/buttonTriggerSos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/send_sos_now"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#E74C3C"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputLayoutKeyword" />

    <!-- Voice Listening Button -->
    <Button
        android:id="@+id/buttonVoiceListen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/start_voice_listening"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#3498DB"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonTriggerSos" />

    <!-- Cancel SOS Button -->
    <Button
        android:id="@+id/buttonCancelSos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/cancel_sos"
        android:backgroundTint="#9B59B6"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonVoiceListen" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/textStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/ready"
        android:textAlignment="center"
        android:textColor="#27AE60"
        android:textSize="16sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/buttonCancelSos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation -->
    <!-- Bottom Navigation Container -->
    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Profile Button -->
        <Button
            android:id="@+id/buttonProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile"
            android:textSize="16sp"
            android:backgroundTint="#3498DB"
            android:layout_marginBottom="8dp" />

        <!-- Contact & Settings Buttons (Horizontal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonContacts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/contacts"
                android:layout_marginEnd="8dp"
                android:textColor="#555555"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/buttonSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings"
                android:layout_marginStart="8dp"
                android:textColor="#555555"
                style="?android:attr/borderlessButtonStyle" />
        </LinearLayout>

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
